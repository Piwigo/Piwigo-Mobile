    "AutoUploadDescription" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إلحاق الصور الأخيرة إلى قائمة انتظار التحميل وفقًا لإعدادات التحميل التلقائي."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilføjer de seneste fotos til uploadkøen i henhold til indstillingerne for automatisk upload."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügt die neuesten Fotos gemäß den Einstellungen für das automatische Hochladen an die Warteschlange für das Hochladen im Hintergrund an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appends recent photos to the upload queue according to auto-upload settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade fotos recientes a la cola de subida de acuerdo con la configuración de las subidas automáticas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoute des photos récentes à la file d'attente suivant les paramètres de transferts automatique."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az automatikus feltöltési beállításoknak megfelelően hozzáadja a legutóbbi fényképeket a feltöltési várólistához."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menambahkan foto-foto terbaru ke antrian unggahan sesuai dengan pengaturan unggahan otomatis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiunge le foto recenti alla coda di caricamento in base alle impostazioni di caricamento automatico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動アップロード設定に従って、アップロードキューに最近の写真を追加します。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voegt recente foto's toe aan de uploadwachtrij volgens de instellingen voor automatisch uploaden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodaje ostatnie zdjęcia do kolejki wysyłania zgodnie z ustawieniami automatycznego wysyłania."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляет последние фотографии в очередь загрузки в соответствии с настройками автозагрузки."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lägger till de senaste bilderna i uppladdningskön enligt inställningarna för automatisk uppladdning."
