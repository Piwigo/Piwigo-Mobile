    "CoreData_MigrationError_timeout" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تعليق التطبيق أثناء ترحيل قاعدة البيانات. الرجاء إعادة تشغيل التطبيق والمحاولة مرة أخرى."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appen blev suspenderet, mens databasen blev migreret. Genstart venligst appen og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anwendung wurde während der Migration der Datenbank angehalten. Bitte starten Sie die Anwendung neu und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app was suspended while migrating the database. Please restart the app and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La aplicación se ha suspendido durante la migración de la base de datos. Reinicie la aplicación e inténtelo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'application a été suspendue lors de la migration de la base de données. Veuillez redémarrer l'application et réessayer."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az alkalmazás felfüggesztésre került az adatbázis migrálása közben. Kérjük, indítsa újra az alkalmazást, és próbálja meg újra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikasi dihentikan sementara saat memigrasikan basis data. Silakan mulai ulang aplikasi dan coba lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'applicazione è stata sospesa durante la migrazione del database. Riavviare l'applicazione e riprovare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "データベースの移行中にアプリが停止しました。アプリを再起動して再試行してください。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De app werd opgeschort tijdens het migreren van de database. Start de app opnieuw op en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikacja zawiesiła się podczas migracji bazy danych. Uruchom ponownie aplikację i spróbuj ponownie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Работа приложения была приостановлена во время миграции базы данных. Пожалуйста, перезапустите приложение и повторите попытку."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appen avbröts medan databasen migrerades. Vänligen starta om appen och försök igen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "迁移数据库时暂停了应用程序。请重启应用程序并重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "應用程式在遷移資料庫時暫停。請重新啟動應用程式並重試。"
          }
        }
      }
    },
