    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدم معرف الوجه بدلاً من رمز المرور للوصول إلى الألبومات الخاصة بك."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brug Ansigts-ID i stedet for en adgangskode for at få adgang til dine albummer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie Face ID anstelle eines Passworts um auf Ihre Alben zuzugreifen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Use Face ID instead of a passcode to access your albums."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice Face ID en lugar de un código de acceso para acceder a sus álbumes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez Face ID au lieu d'un mot de passe pour accéder à vos albums."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Használja a Face ID-t jelszó helyett az albumok eléréséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gunakan ID Wajah alih-alih kode sandi untuk mengakses album Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa Face ID invece di un codice di accesso per accedere ai tuoi album."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスコードの代わりに Face ID を使用してアルバムにアクセスします。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gebruik Face ID in plaats van een toegangscode om toegang te krijgen tot je albums."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użyj Face ID zamiast hasła, aby uzyskać dostęp do swoich albumów."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Face ID вместо секретного кода для доступа к альбомам."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
