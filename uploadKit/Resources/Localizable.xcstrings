    "backgroundTask_lowPowerMode" : {
      "comment" : "Low power mode enabled. Please turn it off.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تمكين وضع توفير الطاقة. يرجى إيقاف تشغيله."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lavt strømforbrug aktiveret. Slå den venligst fra."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energiesparmodus aktiviert. Bitte schalten Sie ihn aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low power mode enabled. Please turn it off."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modo de bajo consumo activado. Por favor desactívelo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mode économie d’énergie activé. Veuillez le désactiver."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energiatakarékos mód engedélyezve. Kérjük, kapcsolja ki."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mode hemat daya diaktifkan. Silakan matikan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modalità risparmio energetico attivata. Disattivala."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "省電力モードが有効になっています。無効にしてください。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lage energie modus ingeschakeld. Schakel deze uit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włączono tryb oszczędzania energii. Wyłącz go."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включен режим энергосбережения. Выключите его."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Energisparläge aktiverat. Stäng av det."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已启用省电模式。请将其关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已啟用省電模式。請將其關閉。"
          }
        }
      }
    },
    "backgroundTask_noWifi" : {
      "comment" : "Wi-Fi only uploading. Please connect to Wi-Fi.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التحميل عبر شبكة Wi-Fi فقط. يرجى الاتصال بشبكة Wi-Fi."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wi-Fi uploader blot. Opret venligst forbindelse til Wi-Fi."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur bei WLAN hochladen aktiviert. Bitte mit WLAN verbinden."
          }
