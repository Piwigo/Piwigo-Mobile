        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengunggahan hanya melalui Wi-Fi. Silakan sambungkan ke Wi-Fi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caricamento solo tramite Wi-Fi. Connettiti al Wi-Fi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wi-Fi 接続時のみアップロード可能です。Wi-Fi に接続してください。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wi-Fi alleen uploaden. Maak verbinding met wifi."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przesyłanie odbywa się wyłącznie przez Wi-Fi. Połącz się z siecią Wi-Fi."
