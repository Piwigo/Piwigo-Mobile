    "backgroundTask_cancelled" : {
      "comment" : "Uploads interrupted. Please restart the app.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمت مقاطعة عمليات التحميل. يرجى إعادة تشغيل التطبيق."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uploads afbrudt. Genstart app'en."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uploads unterbrochen. Bitte starten Sie die App neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uploads interrupted. Please restart the app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subidas interrumpidas. Por favor, reinicie la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transferts interrompus. Veuillez redémarrer l'application."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A feltöltés megszakadt. Kérjük, indítsa újra az alkalmazást."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengunggahan terputus. Silakan jalankan ulang aplikasi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caricamenti interrotti. Riavvia l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アップロードが中断されました。アプリを再起動してください。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uploads onderbroken. Herstart de app aub."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przesyłanie zostało przerwane. Uruchom aplikację ponownie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузка прервана. Перезапустите приложение."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uppladdningen avbröts. Starta om appen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上传中断。请重新启动应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "上傳中斷。請重新啟動應用程式。"
          }
        }
      }
    },
