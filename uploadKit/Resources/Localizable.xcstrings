          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅限 Wi-Fi 上传。请连接 Wi-Fi。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅限 Wi-Fi 上傳。請連線至 Wi-Fi。"
